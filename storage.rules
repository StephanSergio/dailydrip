rules_version = '2';

// Project-wide Storage rules (fitnessapp-92b38). DailyDrip uploads wardrobe
// photos under the `wardrobe/` prefix.
//
// ⚠️ If Mercato or CleanFit also store files, ADD their paths below before
// deploying — anything not matched falls through to the locked catch-all and
// will break. If you're unsure what else uses Storage, replace the catch-all
// with `allow read, write: if true;` instead of locking it.
service firebase.storage {
  match /b/{bucket}/o {

    // ── DailyDrip — wardrobe photos, no login, single-user ──
    match /wardrobe/{allPaths=**} {
      allow read, write: if true;
    }

    // ── Add other apps' storage paths here (e.g. CleanFit) ──
    // match /users/{userId}/{allPaths=**} {
    //   allow read, write: if request.auth != null && request.auth.uid == userId;
    // }

    // Everything else stays locked.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
