# Firebase web app config (Project Settings -> General -> Your apps -> SDK setup)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=

# URL of your Cloudflare Worker proxy (holds the Anthropic key server-side).
# Safe to expose — it's just a URL. See worker/ and the README.
VITE_ANTHROPIC_PROXY_URL=
