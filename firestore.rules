rules_version = '2';

// ⚠️ OPEN RULES — single-user app. Anyone with the project config can read and
// write all data. Harden before sharing the app URL (add Firebase Auth and
// scope access to the authenticated user, or restrict by an allowlist).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
